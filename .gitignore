# =============================================================================
# .gitignore — cloud-operations-readiness-skill
#
# Covers: Python, pytest, ruff, mypy, pre-commit, editors, and OS artefacts.
# Generated from first principles; not a template dump.
# =============================================================================

# ---------------------------------------------------------------------------
# Python bytecode and cache
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ---------------------------------------------------------------------------
# Distribution and packaging
# ---------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/
wheels/
pip-wheel-metadata/
share/python-wheels/

# ---------------------------------------------------------------------------
# Editable install artefacts (PEP 660 / setuptools)
# ---------------------------------------------------------------------------
*.dist-info/
__editable__.*

# ---------------------------------------------------------------------------
# Virtual environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/
# Python version managers
.python-version

# ---------------------------------------------------------------------------
# pytest
# ---------------------------------------------------------------------------
.pytest_cache/
htmlcov/
.coverage
.coverage.*
coverage.xml
coverage.json

# ---------------------------------------------------------------------------
# ruff
# ---------------------------------------------------------------------------
.ruff_cache/

# ---------------------------------------------------------------------------
# mypy
# ---------------------------------------------------------------------------
.mypy_cache/
*.pyi
# Keep .pyi stubs only if committed intentionally — exclude generated ones.
# (No stubs in this project; rule is a safeguard.)

# ---------------------------------------------------------------------------
# pre-commit
# ---------------------------------------------------------------------------
.pre-commit-hooks.yaml.bak

# ---------------------------------------------------------------------------
# Editors and IDEs
# ---------------------------------------------------------------------------
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ, etc.)
.idea/
*.iml
*.ipr
*.iws

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# Operating system
# ---------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory

# ---------------------------------------------------------------------------
# Temporary and build output
# ---------------------------------------------------------------------------
*.tmp
*.bak
*.orig
*.log
*.pid
*.seed

# ---------------------------------------------------------------------------
# Secrets — never commit these
# ---------------------------------------------------------------------------
.env
*.env
secrets.*
credentials.*
*.pem
*.key
*.p12
*.pfx
